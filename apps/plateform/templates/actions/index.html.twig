{% extends 'base.html.twig' %}

{% block body %}
    <header class="hero-header">
        <h1>KERES</h1>
        <p class="hero-baseline">The art of abstract play</p>
        <a href="{{ path('new_game') }}" class="btn btn-outline">Play for Free</a>
        <div class="hero-img">
            <img src="{{ asset('images/landing-dark.webp') }}" alt="Keres Board" class="w-full h-full object-cover"/>
        </div>
        <div class="hero-content">
            <p>
                Keres draws from classic strategy games and enriches them with an elegant stacking mechanic.
                This innovation opens new tactical territory to explore, where every game challenges your intelligence
                rather than your memory. Fresh playing ground, deep decisions, renewed freedom.
            </p>
        </div>
    </header>

    <!-- Concept Section -->
    <section class="">
        <div class="">
            <h2>Pure tactics, total freedom</h2>
            <p>A two-player duel, no randomness, no hidden information.
                Keres gives you a tactical space where stacking your pieces amplifies their movement, while
                separating
                them multiplies your threats. No fixed meta, no optimal build. Just you, your opponent, and the
                satisfaction of seeing your strategies come to life on the board.</p>
            <ul>
                <li>Zero randomness, complete information</li>
                <li>Your style, your strategies</li>
                <li>Games last 30 to 50 minutes</li>
            </ul>
        </div>
        <div class="">
            <img src="{{ asset('images/gameplay-preview.webp') }}" alt="Gameplay Preview"
                 class=""/>
        </div>
    </section>

    <!-- Author/Vision Section -->
    <section class="">
        <div class="">
            <img src="{{ asset('images/avatar.webp') }}" alt="Author Avatar"
                 class=""/>
        </div>
        <div class="">
            <h3 class="">Vincent Chalnot
                - Web Developer & Indie Game Designer</h3>
            <p>
                A lover of abstract strategy games (Go, Shogi, chess), I created Keres to
                recapture what fascinates me: simple rules, infinite depth. As a perfectionist developer and maker,
                I designed every aspect of the project — from game engine to web platform, from engraved pieces to
                interface design.
            </p>
            <p>
                <b>My ambition:</b> build a community around Keres, organize tournaments, and deliver a premium
                experience
                that honors the classics while opening new territory. Keres is designed to be played online first,
                because that's where we actually find time to play.</p>
        </div>
    </section>

    <!-- Pre-order Section -->
    <section class="">
        <div class="">
            <div class="">
                <div class="">
                    <!-- Replace src with actual box image when available -->
                    <img src="{{ asset('/images/board-preview-sm.webp') }}" alt="Keres Box" class=""/>
                </div>
            </div>
            <div class="">
                <h4 class="">Collector's Edition</h4>
                <p class="">Pre-order the physical edition and own a piece of strategy
                    history.</p>
                <div class="">45€</div>
                <a href="#" class="btn primary">Pre-order Collector's Edition</a>
            </div>
        </div>
    </section>

    <!-- Newsletter Section -->
    <section class="">
        <div class="">
            <h5 class="">Stay Updated</h5>
            <form class="">
                <label for="newsletter" class="">Email address</label>
                <input type="email" id="newsletter" placeholder="Your email address"
                       class=""
                       required/>
                <button type="submit" class="btn primary">
                    Subscribe
                </button>
            </form>
            <p class="">We respect your privacy. Your email will only be used for Keres
                updates. Unsubscribe anytime.</p>
        </div>
    </section>

    <!-- Footer -->
    <footer class="">
        <div class="">
            <div class="">&copy; Keres 2025</div>
            <div class="">
                <a href="#" class="">Legal Notice</a>
                <a href="#" class="">Terms of Sales</a>
                <a href="#" class="">Contact</a>
            </div>
        </div>
    </footer>
{% endblock %}
