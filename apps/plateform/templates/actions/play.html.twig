{% extends 'base.html.twig' %}

{% block body %}
    <section class="section">
        <div class="container">
            <h2 class="title">Keres</h2>
            <div class="game-container">
                <div class="main-container">
                    <div id="board-container"></div>
                    <div id="status">Loading...</div>
                    <div class="buttons mt-4">
                        <a href="/" class="button is-warning">Reset board</a>
                        <button class="button is-primary" id="switch-sides-btn">Switch Sides</button>
                        <button class="button is-info" id="ask-engine-btn">Ask MCTS Engine</button>
                        <button class="button is-success" id="ask-minimax-btn">Ask Minimax Engine</button>
                        <button class="button is-link" id="toggle-threats-btn">Hide Threats</button>
                    </div>
                </div>
                <div class="move-history">
                    <label class="label" for="move-history">Move History</label>
                    <textarea class="textarea" id="move-history" placeholder=""></textarea>
                    <div class="buttons mt-2">
                        <button class="button is-info" id="load-game-btn">Load</button>
                        <button class="button is-warning" id="undo-btn">Undo</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="modal" id="unstack-modal">
        <div class="modal-background"></div>
        <div class="modal-card">
            <header class="modal-card-head">
                <p class="modal-card-title">Choose your move</p>
            </header>
            <section class="modal-card-body">
                <p>You are moving a stacked piece. Do you want to move the full stack or only the top piece?</p>
            </section>
            <footer class="modal-card-foot">
                <button class="button" id="move-stack">Move Full Stack</button>
                <button class="button" id="move-unstack">Move Top Piece</button>
            </footer>
        </div>
    </div>
{% endblock %}

{% block end_javascripts %}
    {{ vite_entry_script_tags('board') }}
{% endblock %}
