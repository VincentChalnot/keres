# Production environment for deploy/compose.yaml.
# Place next to compose.yaml on the prod server. Never commit .env.

SERVER_NAME=playkeres.com
APP_SECRET=                          # 32+ random chars
POSTGRES_USER=app
POSTGRES_PASSWORD=                   # strong secret
POSTGRES_DB=app
POSTGRES_VERSION=16
POSTGRES_CHARSET=utf8
MERCURE_JWT_SECRET=                  # 32+ random chars

# Tighten to the proxy network CIDR actually used by Traefik.
TRUSTED_PROXIES=172.16.0.0/12,::/0

# Docker image tag to deploy.
IMAGES_TAG=latest

# Cert resolver name as configured on the prod Traefik.
CERT_RESOLVER=infomaniak

# Name of the external docker network the shared Traefik instance listens on.
# TRAEFIK_NETWORK=proxy

# Entrypoint names configured on the external Traefik instance.
# TRAEFIK_ENTRYPOINT=websecure
# TRAEFIK_HTTP_ENTRYPOINT=web

# Both default to the `backend` container.
# BACKEND_API_URL=http://backend:3000
# AI_BACKEND_API_URL=http://backend:3000

# MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# Defaults to null://null (no-op) — set a real DSN to actually send mail.
# MAILER_DSN=

# Regex matched against the Origin header for CORS.
# CORS_ALLOW_ORIGIN=^https://playkeres\.com$

# Blank by default — that provider's login stays unavailable until set.
# OIDC_GOOGLE_CLIENT_ID=
# OIDC_GOOGLE_CLIENT_SECRET=
# OIDC_FACEBOOK_CLIENT_ID=
# OIDC_FACEBOOK_CLIENT_SECRET=
# OIDC_DISCORD_CLIENT_ID=
# OIDC_DISCORD_CLIENT_SECRET=
