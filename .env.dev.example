# Development environment defaults for docker compose at workspace root.
# Copy to .env and adjust secrets if needed. Do NOT commit .env.

# Comma-separated CIDR/IPs trusted to set X-Forwarded-* headers.
# Default covers docker default subnets; tighten to the proxy network CIDR.
TRUSTED_PROXIES=172.16.0.0/12,::/0

# Cert resolver configured on the external Traefik instance.
CERT_RESOLVER=letsencrypt

# Database (dev defaults — change if you want).
POSTGRES_USER=app
POSTGRES_PASSWORD=!ChangeMe!
POSTGRES_DB=app
POSTGRES_VERSION=16

# Symfony
APP_SECRET=dev-secret-not-for-production

# Mercure (dev)
MERCURE_JWT_SECRET=!ChangeThisMercureHubJWTSecretKey!

# OIDC providers — fill these in locally if you want to test login.
# Ensure callback URL registered in each provider's console is:
#   https://app.local.playkeres.com/auth/callback
OIDC_GOOGLE_CLIENT_ID=
OIDC_GOOGLE_CLIENT_SECRET=
OIDC_DISCORD_CLIENT_ID=
OIDC_DISCORD_CLIENT_SECRET=
OIDC_FACEBOOK_CLIENT_ID=
OIDC_FACEBOOK_CLIENT_SECRET=

# Mailer (Mailpit in compose)
MAILER_DSN=smtp://mailer:1025

# CORS (regex matched against Origin header)
CORS_ALLOW_ORIGIN=^https://(local\.playkeres\.com|playkeres\.com)$
