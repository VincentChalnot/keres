{% extends 'base.html.twig' %}

{% block topnav %}{% endblock %}

{% block body %}
    <header class="hero-header">
        <h1>KERES</h1>
        <p class="hero-baseline">The art of abstract play</p>
        <a href="{{ path('new_game') }}" class="button is-rounded is-outlined is-light">Play for Free</a>
        <div class="hero-img">
            <img src="{{ asset('images/landing-dark.webp') }}" alt="Keres Board"/>
        </div>
        <div class="hero-content">
            <p>
                Keres draws from classic strategy games and enriches them with an elegant stacking mechanic.
                This innovation opens new tactical territory to explore, where every game challenges your intelligence
                rather than your memory. Fresh playing ground, deep decisions, renewed freedom.
            </p>
        </div>
    </header>

    <!-- Concept Section -->
    <section class="section section-flex">
        <div class="section-content">
            <h2>Pure tactics, total freedom</h2>
            <p>A two-player duel, no randomness, no hidden information.
                Keres gives you a tactical space where stacking your pieces amplifies their movement, while
                separating
                them multiplies your threats. No fixed meta, no optimal build. Just you, your opponent, and the
                satisfaction of seeing your strategies come to life on the board.</p>
            <ul>
                <li>Zero randomness, complete information</li>
                <li>Your style, your strategies</li>
                <li>Games last 30 to 50 minutes</li>
            </ul>
        </div>
        <div class="section-img">
            <a href="{{ asset('images/board-art-01.webp') }}" class="lightbox-trigger">
                <img src="{{ asset('images/gameplay-preview.webp') }}" alt="Gameplay Preview"/>
            </a>
            <a href="{{ path('rules') }}" class="button is-rounded is-primary">Read the rules</a>
        </div>
    </section>

    <!-- Author/Vision Section -->
    <section class="section section-flex">
        <div class="section-img">
            <img src="{{ asset('images/avatar.webp') }}" alt="Author Avatar"/>
        </div>
        <div>
            <h3>Vincent Chalnot
                - Web Developer & Indie Game Designer</h3>
            <p>
                A lover of abstract strategy games (Go, Shogi, chess), I created Keres to
                recapture what fascinates me: simple rules, infinite depth. As a perfectionist developer and maker,
                I designed every aspect of the project — from game engine to web platform, from engraved pieces to
                interface design.
            </p>
            <p>
                <b>My ambition:</b> build a community around Keres, organize tournaments, and deliver a premium
                experience
                that honors the classics while opening new territory. Keres is designed to be played online first,
                because that's where we actually find time to play.</p>
        </div>
    </section>

    <!-- Pre-order Section -->
    <section class="section section-flex">
        <div>
            <h4>Collector's Edition</h4>
            <p>Pre-order the physical edition and own a piece of strategy
                history.</p>
            <p class="title is-4">45€</p>
            <a href="#" class="button is-rounded is-primary">Pre-order Collector's Edition</a>
        </div>
        <div class="section-img">
            <a href="{{ asset('/images/real_board_full.webp') }}" class="lightbox-trigger">
                <img src="{{ asset('/images/real_board_small.webp') }}" alt="Keres Box"/>
            </a>
        </div>
    </section>

    <!-- Newsletter Section -->
    <section class="section section-flex">
        <div>
            <h5>Stay Updated</h5>
            <form>
                <div class="field">
                    <label class="label" for="newsletter">Email address</label>
                    <div class="control">
                        <input class="input" type="email" id="newsletter" placeholder="Your email address" required/>
                    </div>
                </div>
                <div class="field">
                    <div class="control">
                        <button type="submit" class="button is-rounded is-primary">Subscribe</button>
                    </div>
                </div>
            </form>
            <p class="mt-4">We respect your privacy. Your email will only be used for Keres
                updates. Unsubscribe anytime.</p>
        </div>
    </section>

    <!-- Lightbox overlay -->
    <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer">
        <button class="lightbox__close" id="lightbox-close" aria-label="Close">&times;</button>
        <img class="lightbox__img" id="lightbox-img" src="" alt=""/>
    </div>

{% endblock %}

{% block footer %}
    <footer class="footer">
        <div class="content has-text-centered">
            <p>&copy; Keres 2025-2026</p>
            <nav>
                <a href="{{ path('legal_notice') }}">Mentions légales</a>
                <a href="{{ path('terms') }}">Conditions générales de vente</a>
                <a href="{{ path('contact') }}">Contact</a>
            </nav>
        </div>
    </footer>
{% endblock %}
