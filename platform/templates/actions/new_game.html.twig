{% extends 'base.html.twig' %}

{% block body %}
    <section class="section">
        <div class="container">
            <div class="columns is-centered">
                <div class="column is-half">
                    <div class="box">
                        <h3 class="title">New Game</h3>
                        <p class="subtitle">Configure your game settings</p>

                        {{ form_start(form) }}

                        <div class="field">
                            {{ form_label(form.playerSide, null, {label_attr: {class: 'label'}}) }}
                            <div class="control">
                                <div class="select">
                                    {{ form_widget(form.playerSide) }}
                                </div>
                            </div>
                            {{ form_errors(form.playerSide) }}
                        </div>

                        <div class="field">
                            {{ form_label(form.opponentType, null, {label_attr: {class: 'label'}}) }}
                            <div class="control">
                                <div class="select">
                                    {{ form_widget(form.opponentType) }}
                                </div>
                            </div>
                            {{ form_errors(form.opponentType) }}
                        </div>

                        <div class="field">
                            <div class="control">
                                {{ form_widget(form.submit, {attr: {class: 'button is-rounded is-primary'}}) }}
                            </div>
                        </div>

                        {{ form_end(form) }}
                    </div>

                    <h3 class="title is-4 mt-5">In Progress</h3>
                    {% for game in inProgressGames %}
                        {# @var game \App\Entity\Game #}
                        <div class="box mb-4">
                            <a href="{{ path('play', {uuid: game.uuid}) }}" class="button is-rounded is-primary is-pulled-right">Resume</a>
                            <form method="post" action="{{ path('delete_game', {uuid: game.uuid}) }}" style="display:inline" class="is-pulled-right mr-2" onsubmit="return confirm('Are you sure you want to delete this game?')">
                                <button type="submit" class="button is-rounded is-small is-danger is-outlined">Delete</button>
                            </form>
                            <p><strong>Player Side:</strong> {{ game.white ? 'White' : 'Black' }}</p>
                            <p><strong>Opponent Type:</strong>
                                {% if game.opponentType == enum('App\\Model\\OpponentType').AI %}
                                    AI
                                {% elseif game.opponentType == enum('App\\Model\\OpponentType').HOTSEAT %}
                                    Hot Seat
                                {% else %}
                                    Unknown
                                {% endif %}
                            </p>
                            <p><strong>Created:</strong> {{ game.createdAt|date('Y-m-d H:i') }}</p>
                            {% if game.lastMoveAt %}
                                <p><strong>Last Move:</strong> {{ game.lastMoveAt|date('Y-m-d H:i') }}</p>
                            {% endif %}
                            <p><strong>Next to play:</strong> {{ game.whiteTurn ? 'White' : 'Black' }}</p>
                        </div>
                    {% else %}
                        <p>No games in progress.</p>
                    {% endfor %}

                    <h3 class="title is-4 mt-5">Finished</h3>
                    {% for game in finishedGames %}
                        {# @var game \App\Entity\Game #}
                        <div class="box mb-4">
                            <a href="{{ path('play', {uuid: game.uuid}) }}" class="button is-rounded is-static is-pulled-right">Game Over</a>
                            <form method="post" action="{{ path('delete_game', {uuid: game.uuid}) }}" style="display:inline" class="is-pulled-right mr-2" onsubmit="return confirm('Are you sure you want to delete this game?')">
                                <button type="submit" class="button is-rounded is-small is-danger is-outlined">Delete</button>
                            </form>
                            <p><strong>Player Side:</strong> {{ game.white ? 'White' : 'Black' }}</p>
                            <p><strong>Opponent Type:</strong>
                                {% if game.opponentType == enum('App\\Model\\OpponentType').AI %}
                                    AI
                                {% elseif game.opponentType == enum('App\\Model\\OpponentType').HOTSEAT %}
                                    Hot Seat
                                {% else %}
                                    Unknown
                                {% endif %}
                            </p>
                            <p><strong>Created:</strong> {{ game.createdAt|date('Y-m-d H:i') }}</p>
                            {% if game.lastMoveAt %}
                                <p><strong>Last Move:</strong> {{ game.lastMoveAt|date('Y-m-d H:i') }}</p>
                            {% endif %}
                            <p><strong>Result:</strong>
                                {% if game.draw %}
                                    Draw
                                {% elseif game.whiteWins %}
                                    White wins
                                {% else %}
                                    Black wins
                                {% endif %}
                            </p>
                        </div>
                    {% else %}
                        <p>No finished games.</p>
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>
{% endblock %}
